<section id="quote" class="section quote-section">
  <div class="container">
    <div class="quote-layout">
      <!-- Left editorial column -->
      <div class="quote-editorial">
        <span class="section-label" style="text-align:left">Complimentary Estimate</span>
        <h2>Request Your<br>Personalized Quote</h2>
        <div class="ed-rule"></div>
        <p>Describe your rugs and we'll prepare a detailed estimate. Most quotes are returned within two hours during business hours.</p>

        <ul class="ed-perks">
          <li>No obligation, entirely complimentary</li>
          <li>White-glove pickup & delivery included</li>
          <li>Volume discounts for 3+ pieces</li>
          <li>5–7 day standard turnaround</li>
        </ul>

        <div class="ed-image">
          <img
            src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=80&auto=format"
            alt="Elegant interior with restored rug"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Right form column -->
      <div class="quote-form-card">
        <!-- Progress -->
        <div class="progress-bar" id="progressBar">
          <div class="progress-step active" data-step="1">
            <span class="p-num">1</span><span class="p-label">Your Rugs</span>
          </div>
          <div class="progress-line"><div class="progress-fill" id="progressFill"></div></div>
          <div class="progress-step" data-step="2">
            <span class="p-num">2</span><span class="p-label">Preferences</span>
          </div>
          <div class="progress-line"><div class="progress-fill"></div></div>
          <div class="progress-step" data-step="3">
            <span class="p-num">3</span><span class="p-label">Contact</span>
          </div>
        </div>

        <!-- STEP 1: Rug details -->
        <div class="form-step" id="step1">
          <div id="rugCards"></div>
          <button type="button" class="btn-add" id="addRugBtn">
            <span>+</span> Add Another Rug
          </button>
          <div class="step-actions">
            <div></div>
            <button type="button" class="btn btn-primary" id="toStep2">Continue</button>
          </div>
        </div>

        <!-- STEP 2: Options + live price -->
        <div class="form-step" id="step2" style="display:none">
          <div class="field-group">
            <label class="field-label">Timeline</label>
            <div class="toggle-row">
              <label class="toggle-card">
                <input type="radio" name="timeline" value="standard" checked />
                <div class="toggle-inner">
                  <strong>Standard</strong>
                  <span>5–7 business days</span>
                </div>
              </label>
              <label class="toggle-card">
                <input type="radio" name="timeline" value="rush" />
                <div class="toggle-inner">
                  <strong>Rush</strong>
                  <span>2–3 days (+25%)</span>
                </div>
              </label>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label">Additional Services</label>
            <label class="check-row">
              <input type="checkbox" id="addonStain" />
              <div>Stain Protection Coating <span class="check-rate">$1.50/sqft</span></div>
            </label>
            <label class="check-row">
              <input type="checkbox" id="addonMoth" />
              <div>Moth Prevention Treatment <span class="check-rate">$0.50/sqft</span></div>
            </label>
          </div>

          <div class="field-group">
            <label class="field-label" for="notes">Special Instructions</label>
            <textarea id="notes" rows="3" placeholder="Areas of concern, pet stains, fragility, specific requests..."></textarea>
          </div>

          <!-- Live estimate -->
          <div class="estimate-box" id="estimateBox">
            <div class="est-top">
              <span class="est-label">Estimated Total</span>
              <span class="est-price" id="estPrice">$0</span>
            </div>
            <div class="est-lines" id="estLines"></div>
          </div>

          <div class="step-actions">
            <button type="button" class="btn-text" id="backTo1">&larr; Back</button>
            <button type="button" class="btn btn-primary" id="toStep3">Continue</button>
          </div>
        </div>

        <!-- STEP 3: Lead capture -->
        <div class="form-step" id="step3" style="display:none">
          <p class="step-note">We'll send your detailed quote to the contact below.</p>
          <div class="lead-grid">
            <div class="lead-field">
              <label>Full Name *</label>
              <input type="text" id="leadName" required placeholder="Jane Smith" />
            </div>
            <div class="lead-field">
              <label>Phone *</label>
              <input type="tel" id="leadPhone" required placeholder="(408) 555-1234" />
            </div>
            <div class="lead-field span-2">
              <label>Email *</label>
              <input type="email" id="leadEmail" required placeholder="jane@example.com" />
            </div>
            <div class="lead-field span-2">
              <label>Pickup Address</label>
              <input type="text" id="leadAddr" placeholder="123 Main St, San Jose, CA" />
            </div>
            <div class="lead-field span-2">
              <label>How did you find us?</label>
              <select id="leadHow">
                <option value="">Select...</option>
                <option>Google Search</option>
                <option>Yelp</option>
                <option>Nextdoor</option>
                <option>Referral</option>
                <option>Instagram</option>
                <option>Other</option>
              </select>
            </div>
          </div>

          <div class="final-price-bar" id="finalBar"></div>

          <div class="step-actions">
            <button type="button" class="btn-text" id="backTo2">&larr; Back</button>
            <button type="button" class="btn btn-gold btn-wide" id="submitBtn">Submit Quote Request</button>
          </div>
          <p class="fine-print">Your information is private and never shared. Expect a response within 2 hours.</p>
        </div>

        <!-- SUCCESS -->
        <div class="form-step" id="stepDone" style="display:none">
          <div class="success">
            <div class="success-check">&#10003;</div>
            <h3>Quote Request Received</h3>
            <p>Thank you — our team will review your rugs and return a detailed quote shortly.</p>
            <div class="success-detail" id="successDetail"></div>
            <p class="success-call">Questions? <strong>(408) 555-RUGS</strong></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const RATES = {
    cleaningPrice: {
      'Wool': [4.00, 5.50], 'Silk': [5.00, 10.00],
      'Cotton': [3.00, 4.00], 'Other': [2.00, 3.00],
    } as Record<string, number[]>,
    soilRemoval: { 'none': 0, 'light': 0.75, 'medium': 1.50, 'heavy': 3.00 } as Record<string, number>,
    stainProtection: 1.50, mothPrevention: 0.50,
    minimumCharge: 50, taxRate: 0.08, rushSurcharge: 0.25,
    discount3: 0.05, discount5: 0.10,
  };

  let rugId = 0;

  function makeCard(): HTMLElement {
    rugId++;
    const el = document.createElement('div');
    el.className = 'rug-card';
    el.innerHTML = `
      <div class="rc-head">
        <span class="rc-title">Rug <span class="rc-num">${rugId}</span></span>
        <button type="button" class="rc-remove" title="Remove">&times;</button>
      </div>
      <div class="rc-grid">
        <div class="rc-field">
          <label>Material</label>
          <select class="f-material">
            <option value="">Select...</option>
            <option>Wool</option><option>Silk</option><option>Cotton</option><option>Other</option>
          </select>
        </div>
        <div class="rc-field">
          <label>Construction</label>
          <select class="f-construction">
            <option value="">Select...</option>
            <option>Machine-Made</option><option>Hand-Made</option>
          </select>
        </div>
        <div class="rc-field">
          <label>Length (ft)</label>
          <input type="number" class="f-length" min="1" step="0.5" placeholder="10" />
        </div>
        <div class="rc-field">
          <label>Width (ft)</label>
          <input type="number" class="f-width" min="1" step="0.5" placeholder="8" />
        </div>
        <div class="rc-field rc-field-full">
          <label>Condition</label>
          <select class="f-soil">
            <option value="none">Clean — maintenance wash</option>
            <option value="light">Light soiling</option>
            <option value="medium" selected>Moderate stains</option>
            <option value="heavy">Heavy / pet damage</option>
          </select>
        </div>
      </div>
      <div class="rc-foot">
        <span class="rc-sqft"></span>
        <span class="rc-price"></span>
      </div>
    `;
    return el;
  }

  function renumber() {
    document.querySelectorAll('.rug-card').forEach((c, i) => {
      c.querySelector('.rc-num')!.textContent = String(i + 1);
    });
  }

  function calc() {
    const cards = document.querySelectorAll('.rug-card');
    const rush = (document.querySelector('input[name="timeline"][value="rush"]') as HTMLInputElement)?.checked || false;
    const stain = (document.getElementById('addonStain') as HTMLInputElement)?.checked || false;
    const moth = (document.getElementById('addonMoth') as HTMLInputElement)?.checked || false;

    let count = 0, sub = 0, sqftTotal = 0;

    cards.forEach(c => {
      const mat = (c.querySelector('.f-material') as HTMLSelectElement).value;
      const con = (c.querySelector('.f-construction') as HTMLSelectElement).value;
      const l = parseFloat((c.querySelector('.f-length') as HTMLInputElement).value) || 0;
      const w = parseFloat((c.querySelector('.f-width') as HTMLInputElement).value) || 0;
      const soil = (c.querySelector('.f-soil') as HTMLSelectElement).value;
      const sqft = l * w;

      c.querySelector('.rc-sqft')!.textContent = sqft > 0 ? sqft + ' sq ft' : '';
      if (!mat || !con || sqft === 0) { c.querySelector('.rc-price')!.textContent = ''; return; }

      count++;
      sqftTotal += sqft;
      const idx = con === 'Machine-Made' ? 0 : 1;
      const clean = Math.max(sqft * RATES.cleaningPrice[mat][idx], RATES.minimumCharge);
      const soilFee = RATES.soilRemoval[soil] * sqft;
      const line = clean + soilFee;
      sub += line;
      c.querySelector('.rc-price')!.textContent = '$' + line.toFixed(2);
    });

    const stainFee = stain ? sqftTotal * RATES.stainProtection : 0;
    const mothFee = moth ? sqftTotal * RATES.mothPrevention : 0;
    sub += stainFee + mothFee;

    let disc = 0;
    if (count >= 5) disc = RATES.discount5;
    else if (count >= 3) disc = RATES.discount3;

    const discAmt = sub * disc;
    const afterDisc = sub - discAmt;
    const rushAmt = rush ? afterDisc * RATES.rushSurcharge : 0;
    const preTax = afterDisc + rushAmt;
    const tax = preTax * RATES.taxRate;
    const total = preTax + tax;

    const ep = document.getElementById('estPrice');
    if (ep) ep.textContent = count > 0 ? '$' + total.toFixed(2) : '$0';

    const el = document.getElementById('estLines');
    if (el && count > 0) {
      let h = `<div class="el-row"><span>${count} rug${count > 1 ? 's' : ''}, ${sqftTotal} sqft</span><span>$${(sub - stainFee - mothFee).toFixed(2)}</span></div>`;
      if (stainFee) h += `<div class="el-row"><span>Stain protection</span><span>$${stainFee.toFixed(2)}</span></div>`;
      if (mothFee) h += `<div class="el-row"><span>Moth prevention</span><span>$${mothFee.toFixed(2)}</span></div>`;
      if (disc) h += `<div class="el-row el-green"><span>Discount (${(disc*100)}%)</span><span>-$${discAmt.toFixed(2)}</span></div>`;
      if (rushAmt) h += `<div class="el-row el-amber"><span>Rush surcharge</span><span>$${rushAmt.toFixed(2)}</span></div>`;
      h += `<div class="el-row"><span>Tax (8%)</span><span>$${tax.toFixed(2)}</span></div>`;
      el.innerHTML = h;
    } else if (el) { el.innerHTML = ''; }

    const fb = document.getElementById('finalBar');
    if (fb && count > 0) {
      fb.innerHTML = `<div class="fb-inner"><span class="fb-label">Estimated Total</span><span class="fb-price">$${total.toFixed(2)}</span><span class="fb-meta">${count} rug${count > 1 ? 's' : ''} &middot; ${sqftTotal} sqft &middot; ${rush ? 'Rush' : 'Standard'}</span></div>`;
    }

    return { count, total, rush };
  }

  function goTo(n: number) {
    [1, 2, 3].forEach(i => {
      const s = document.getElementById('step' + i);
      if (s) s.style.display = i === n ? '' : 'none';
    });
    document.querySelectorAll('.progress-step').forEach(s => {
      s.classList.toggle('active', Number((s as HTMLElement).dataset.step) <= n);
    });
    // Fill progress lines
    const fills = document.querySelectorAll('.progress-fill') as NodeListOf<HTMLElement>;
    fills[0].style.width = n >= 2 ? '100%' : '0%';
    if (fills[1]) fills[1].style.width = n >= 3 ? '100%' : '0%';
    document.getElementById('quote')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function addRug() {
    const wrap = document.getElementById('rugCards')!;
    const card = makeCard();
    wrap.appendChild(card);
    card.querySelectorAll('select, input').forEach(e => {
      e.addEventListener('input', calc); e.addEventListener('change', calc);
    });
    card.querySelector('.rc-remove')!.addEventListener('click', () => {
      card.remove(); renumber(); calc();
      if (!document.querySelector('.rug-card')) addRug();
    });
    renumber(); calc();
  }

  document.getElementById('addRugBtn')!.addEventListener('click', addRug);
  document.getElementById('toStep2')!.addEventListener('click', () => { calc(); goTo(2); });
  document.getElementById('toStep3')!.addEventListener('click', () => { calc(); goTo(3); });
  document.getElementById('backTo1')!.addEventListener('click', () => goTo(1));
  document.getElementById('backTo2')!.addEventListener('click', () => goTo(2));
  document.querySelectorAll('#step2 input').forEach(e => e.addEventListener('change', calc));

  document.getElementById('submitBtn')!.addEventListener('click', () => {
    const name = (document.getElementById('leadName') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('leadPhone') as HTMLInputElement).value.trim();
    const email = (document.getElementById('leadEmail') as HTMLInputElement).value.trim();
    if (!name || !phone || !email) { alert('Please complete all required fields.'); return; }

    const r = calc();
    document.getElementById('successDetail')!.innerHTML =
      `<p><strong>${name}</strong> &mdash; we'll reach you at ${email}</p>
       <p>Estimate: <strong>$${r.total.toFixed(2)}</strong> for ${r.count} rug${r.count > 1 ? 's' : ''}</p>`;
    [1, 2, 3].forEach(i => { const s = document.getElementById('step' + i); if (s) s.style.display = 'none'; });
    document.getElementById('progressBar')!.style.display = 'none';
    document.getElementById('stepDone')!.style.display = '';
  });

  addRug();
</script>

<style>
  .quote-section {
    background: var(--charcoal);
  }

  .quote-layout {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 56px;
    align-items: start;
  }

  /* Editorial left */
  .quote-editorial h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 400;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .ed-rule {
    width: 32px;
    height: 1px;
    background: var(--gold);
    margin-bottom: 16px;
  }

  .quote-editorial > p {
    color: rgba(255,255,255,0.5);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .ed-perks {
    list-style: none;
    margin-bottom: 32px;
  }

  .ed-perks li {
    color: rgba(255,255,255,0.65);
    font-size: 0.85rem;
    padding: 6px 0;
    padding-left: 20px;
    position: relative;
  }

  .ed-perks li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }

  .ed-image {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .ed-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.8) brightness(0.9);
  }

  /* Form card */
  .quote-form-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 36px;
  }

  /* Progress */
  .progress-bar {
    display: flex;
    align-items: center;
    margin-bottom: 32px;
  }

  .progress-step {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0.35;
    transition: opacity 0.3s;
  }

  .progress-step.active { opacity: 1; }

  .p-num {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    background: var(--stone-100);
    color: var(--stone-500);
    transition: all 0.3s;
  }

  .progress-step.active .p-num {
    background: var(--charcoal);
    color: var(--white);
  }

  .p-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--stone-500);
  }

  .progress-line {
    flex: 1;
    height: 1px;
    background: var(--stone-100);
    margin: 0 12px;
    position: relative;
    overflow: hidden;
  }

  .progress-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0;
    background: var(--gold);
    transition: width 0.4s ease;
  }

  /* Rug cards */
  .quote-form-card :global(.rug-card) {
    border: 1px solid var(--stone-100);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 12px;
    transition: border-color 0.3s;
  }

  .quote-form-card :global(.rug-card:hover) {
    border-color: var(--stone-300);
  }

  .quote-form-card :global(.rc-head) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .quote-form-card :global(.rc-title) {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--charcoal);
  }

  .quote-form-card :global(.rc-remove) {
    background: none;
    border: none;
    color: var(--stone-300);
    font-size: 1.3rem;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
  }

  .quote-form-card :global(.rc-remove:hover) { color: #b44; }

  .quote-form-card :global(.rc-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .quote-form-card :global(.rc-field) {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .quote-form-card :global(.rc-field-full) {
    grid-column: 1 / -1;
  }

  .quote-form-card :global(.rc-field label) {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--stone-500);
  }

  .quote-form-card :global(.rc-field select),
  .quote-form-card :global(.rc-field input) {
    padding: 10px 12px;
    border: 1px solid var(--stone-100);
    border-radius: var(--radius);
    font-size: 0.88rem;
    font-family: var(--font-sans);
    background: var(--warm-white);
    color: var(--charcoal);
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  .quote-form-card :global(.rc-field select:focus),
  .quote-form-card :global(.rc-field input:focus) {
    outline: none;
    border-color: var(--gold);
  }

  .quote-form-card :global(.rc-foot) {
    display: flex;
    justify-content: space-between;
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid var(--stone-100);
    font-size: 0.8rem;
  }

  .quote-form-card :global(.rc-sqft) { color: var(--stone-500); }
  .quote-form-card :global(.rc-price) { font-weight: 600; color: var(--charcoal); }

  .btn-add {
    width: 100%;
    padding: 12px;
    border: 1px dashed var(--stone-200);
    border-radius: var(--radius);
    background: transparent;
    color: var(--stone-500);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
    letter-spacing: 0.02em;
    margin-bottom: 20px;
  }

  .btn-add:hover {
    border-color: var(--gold);
    color: var(--charcoal);
  }

  .step-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4px;
  }

  .btn-text {
    background: none;
    border: none;
    color: var(--stone-500);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    padding: 8px 0;
    font-family: var(--font-sans);
    transition: color 0.2s;
  }

  .btn-text:hover { color: var(--charcoal); }

  /* Step 2 */
  .field-group {
    margin-bottom: 24px;
  }

  .field-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--charcoal);
    margin-bottom: 10px;
  }

  .toggle-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .toggle-card { cursor: pointer; }
  .toggle-card input { display: none; }

  .toggle-inner {
    border: 1px solid var(--stone-100);
    border-radius: var(--radius);
    padding: 14px 16px;
    text-align: center;
    transition: all 0.2s;
  }

  .toggle-inner strong {
    display: block;
    font-size: 0.88rem;
    color: var(--charcoal);
    margin-bottom: 2px;
  }

  .toggle-inner span {
    font-size: 0.75rem;
    color: var(--stone-500);
  }

  .toggle-card input:checked + .toggle-inner {
    border-color: var(--gold);
    background: var(--gold-faint);
  }

  .check-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    cursor: pointer;
    font-size: 0.88rem;
    color: var(--stone-700);
  }

  .check-row input {
    width: 16px;
    height: 16px;
    accent-color: var(--gold);
  }

  .check-rate {
    color: var(--stone-500);
    font-size: 0.78rem;
    margin-left: 4px;
  }

  .field-group textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid var(--stone-100);
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    resize: vertical;
    background: var(--warm-white);
    color: var(--charcoal);
  }

  .field-group textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  /* Estimate box */
  .estimate-box {
    background: var(--warm-white);
    border: 1px solid var(--stone-100);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 20px;
  }

