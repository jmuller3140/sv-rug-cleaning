<section id="quote" class="section quote-section">
  <div class="container">
    <div class="quote-layout">
      <!-- Left editorial column -->
      <div class="quote-editorial">
        <span class="section-label" style="text-align:left">Complimentary Estimate</span>
        <h2>Request Your<br>Personalized Quote</h2>
        <div class="ed-rule"></div>
        <p>Describe your rug and we'll prepare a detailed estimate. Most quotes are returned within two hours during business hours.</p>
        <p class="ed-secondary">No obligation. White-glove pickup and delivery included. Volume discounts available for multiple pieces.</p>

        <div class="ed-image">
          <img
            src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=80&auto=format"
            alt="Elegant interior with restored rug"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Right form column -->
      <div class="quote-form-card">
        <!-- Progress -->
        <div class="progress-bar" id="progressBar">
          <div class="progress-step active" data-step="1">
            <span class="p-num">1</span><span class="p-label">Your Rug</span>
          </div>
          <div class="progress-line"><div class="progress-fill"></div></div>
          <div class="progress-step" data-step="2">
            <span class="p-num">2</span><span class="p-label">Preferences</span>
          </div>
          <div class="progress-line"><div class="progress-fill"></div></div>
          <div class="progress-step" data-step="3">
            <span class="p-num">3</span><span class="p-label">Contact</span>
          </div>
        </div>

        <!-- STEP 1: Rug details — inline, no JS needed for first rug -->
        <div class="form-step" id="step1">
          <div id="rugCards">
            <div class="rug-card" data-rug="1">
              <div class="rc-grid">
                <div class="rc-field">
                  <label>Material</label>
                  <select class="f-material">
                    <option value="">Select...</option>
                    <option value="Wool">Wool</option>
                    <option value="Silk">Silk</option>
                    <option value="Cotton">Cotton</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
                <div class="rc-field">
                  <label>Construction</label>
                  <select class="f-construction">
                    <option value="">Select...</option>
                    <option value="Machine-Made">Machine-Made</option>
                    <option value="Hand-Made">Hand-Made</option>
                  </select>
                </div>
                <div class="rc-field">
                  <label>Length (ft)</label>
                  <input type="number" class="f-length" min="1" step="0.5" placeholder="10" />
                </div>
                <div class="rc-field">
                  <label>Width (ft)</label>
                  <input type="number" class="f-width" min="1" step="0.5" placeholder="8" />
                </div>
                <div class="rc-field rc-field-full">
                  <label>Condition</label>
                  <select class="f-soil">
                    <option value="none">Clean — maintenance wash</option>
                    <option value="light">Light soiling</option>
                    <option value="medium" selected>Moderate stains</option>
                    <option value="heavy">Heavy / pet damage</option>
                  </select>
                </div>
              </div>
              <div class="rc-foot">
                <span class="rc-sqft"></span>
                <span class="rc-price"></span>
              </div>
            </div>
          </div>

          <button type="button" class="btn-add" id="addRugBtn">
            <span>+</span> Add Another Rug
          </button>

          <div class="step-actions">
            <div></div>
            <button type="button" class="btn btn-primary" id="toStep2">Continue</button>
          </div>
        </div>

        <!-- STEP 2: Options + live price -->
        <div class="form-step" id="step2" style="display:none">
          <div class="field-group">
            <label class="field-label">Timeline</label>
            <div class="toggle-row">
              <label class="toggle-card">
                <input type="radio" name="timeline" value="standard" checked />
                <div class="toggle-inner">
                  <strong>Standard</strong>
                  <span>5–7 business days</span>
                </div>
              </label>
              <label class="toggle-card">
                <input type="radio" name="timeline" value="rush" />
                <div class="toggle-inner">
                  <strong>Rush</strong>
                  <span>2–3 days (+25%)</span>
                </div>
              </label>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label">Additional Services</label>
            <label class="check-row">
              <input type="checkbox" id="addonStain" />
              <div>Stain Protection Coating <span class="check-rate">$1.50/sqft</span></div>
            </label>
            <label class="check-row">
              <input type="checkbox" id="addonMoth" />
              <div>Moth Prevention Treatment <span class="check-rate">$0.50/sqft</span></div>
            </label>
          </div>

          <div class="field-group">
            <label class="field-label" for="notes">Special Instructions</label>
            <textarea id="notes" rows="3" placeholder="Areas of concern, pet stains, fragility, specific requests..."></textarea>
          </div>

          <!-- Live estimate -->
          <div class="estimate-box" id="estimateBox">
            <div class="est-top">
              <span class="est-label">Estimated Total</span>
              <span class="est-price" id="estPrice">$0</span>
            </div>
            <div class="est-lines" id="estLines"></div>
          </div>

          <div class="step-actions">
            <button type="button" class="btn-text" id="backTo1">&larr; Back</button>
            <button type="button" class="btn btn-primary" id="toStep3">Continue</button>
          </div>
        </div>

        <!-- STEP 3: Lead capture -->
        <div class="form-step" id="step3" style="display:none">
          <p class="step-note">We'll send your detailed quote to the contact below.</p>
          <div class="lead-grid">
            <div class="lead-field">
              <label>Full Name *</label>
              <input type="text" id="leadName" required placeholder="Jane Smith" />
            </div>
            <div class="lead-field">
              <label>Phone *</label>
              <input type="tel" id="leadPhone" required placeholder="(408) 555-1234" />
            </div>
            <div class="lead-field span-2">
              <label>Email *</label>
              <input type="email" id="leadEmail" required placeholder="jane@example.com" />
            </div>
            <div class="lead-field span-2">
              <label>Pickup Address</label>
              <input type="text" id="leadAddr" placeholder="123 Main St, San Jose, CA" />
            </div>
            <div class="lead-field span-2">
              <label>How did you find us?</label>
              <select id="leadHow">
                <option value="">Select...</option>
                <option>Google Search</option>
                <option>Yelp</option>
                <option>Nextdoor</option>
                <option>Referral</option>
                <option>Instagram</option>
                <option>Other</option>
              </select>
            </div>
          </div>

          <div class="final-price-bar" id="finalBar"></div>

          <div class="step-actions">
            <button type="button" class="btn-text" id="backTo2">&larr; Back</button>
            <button type="button" class="btn btn-gold btn-wide" id="submitBtn">Submit Quote Request</button>
          </div>
          <p class="fine-print">Your information is private and never shared. Expect a response within 2 hours.</p>
        </div>

        <!-- SUCCESS -->
        <div class="form-step" id="stepDone" style="display:none">
          <div class="success">
            <div class="success-check">&#10003;</div>
            <h3>Quote Request Received</h3>
            <p>Thank you — our team will review your rugs and return a detailed quote shortly.</p>
            <div class="success-detail" id="successDetail"></div>
            <p class="success-call">Questions? <strong>(408) 555-RUGS</strong></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var RATES = {
      cleaningPrice: {
        'Wool': [4.00, 5.50], 'Silk': [5.00, 10.00],
        'Cotton': [3.00, 4.00], 'Other': [2.00, 3.00],
      },
      soilRemoval: { 'none': 0, 'light': 0.75, 'medium': 1.50, 'heavy': 3.00 },
      stainProtection: 1.50, mothPrevention: 0.50,
      minimumCharge: 50, taxRate: 0.08, rushSurcharge: 0.25,
      discount3: 0.05, discount5: 0.10,
    };

    var rugCount = 1;

    function makeCard() {
      rugCount++;
      var el = document.createElement('div');
      el.className = 'rug-card';
      el.dataset.rug = String(rugCount);
      el.innerHTML =
        '<div class="rc-head">' +
          '<span class="rc-title">Rug ' + rugCount + '</span>' +
          '<button type="button" class="rc-remove" title="Remove">&times;</button>' +
        '</div>' +
        '<div class="rc-grid">' +
          '<div class="rc-field"><label>Material</label>' +
            '<select class="f-material"><option value="">Select...</option><option value="Wool">Wool</option><option value="Silk">Silk</option><option value="Cotton">Cotton</option><option value="Other">Other</option></select></div>' +
          '<div class="rc-field"><label>Construction</label>' +
            '<select class="f-construction"><option value="">Select...</option><option value="Machine-Made">Machine-Made</option><option value="Hand-Made">Hand-Made</option></select></div>' +
          '<div class="rc-field"><label>Length (ft)</label><input type="number" class="f-length" min="1" step="0.5" placeholder="10" /></div>' +
          '<div class="rc-field"><label>Width (ft)</label><input type="number" class="f-width" min="1" step="0.5" placeholder="8" /></div>' +
          '<div class="rc-field rc-field-full"><label>Condition</label>' +
            '<select class="f-soil"><option value="none">Clean — maintenance wash</option><option value="light">Light soiling</option><option value="medium" selected>Moderate stains</option><option value="heavy">Heavy / pet damage</option></select></div>' +
        '</div>' +
        '<div class="rc-foot"><span class="rc-sqft"></span><span class="rc-price"></span></div>';
      return el;
    }

    function wireCard(card) {
      var inputs = card.querySelectorAll('select, input');
      for (var i = 0; i < inputs.length; i++) {
        inputs[i].addEventListener('input', calc);
        inputs[i].addEventListener('change', calc);
      }
      var rm = card.querySelector('.rc-remove');
      if (rm) {
        rm.addEventListener('click', function() {
          card.remove();
          calc();
        });
      }
    }

    function calc() {
      var cards = document.querySelectorAll('.rug-card');
      var rushEl = document.querySelector('input[name="timeline"][value="rush"]');
      var rush = rushEl ? rushEl.checked : false;
      var stainEl = document.getElementById('addonStain');
      var stain = stainEl ? stainEl.checked : false;
      var mothEl = document.getElementById('addonMoth');
      var moth = mothEl ? mothEl.checked : false;

      var count = 0, sub = 0, sqftTotal = 0;

      for (var i = 0; i < cards.length; i++) {
        var c = cards[i];
        var mat = c.querySelector('.f-material').value;
        var con = c.querySelector('.f-construction').value;
        var l = parseFloat(c.querySelector('.f-length').value) || 0;
        var w = parseFloat(c.querySelector('.f-width').value) || 0;
        var soil = c.querySelector('.f-soil').value;
        var sqft = l * w;

        c.querySelector('.rc-sqft').textContent = sqft > 0 ? sqft + ' sq ft' : '';
        if (!mat || !con || sqft === 0) { c.querySelector('.rc-price').textContent = ''; continue; }

        count++;
        sqftTotal += sqft;
        var idx = con === 'Machine-Made' ? 0 : 1;
        var clean = Math.max(sqft * RATES.cleaningPrice[mat][idx], RATES.minimumCharge);
        var soilFee = RATES.soilRemoval[soil] * sqft;
        var line = clean + soilFee;
        sub += line;
        c.querySelector('.rc-price').textContent = '$' + line.toFixed(2);
      }

      var stainFee = stain ? sqftTotal * RATES.stainProtection : 0;
      var mothFee = moth ? sqftTotal * RATES.mothPrevention : 0;
      sub += stainFee + mothFee;

      var disc = 0;
      if (count >= 5) disc = RATES.discount5;
      else if (count >= 3) disc = RATES.discount3;

      var discAmt = sub * disc;
      var afterDisc = sub - discAmt;
      var rushAmt = rush ? afterDisc * RATES.rushSurcharge : 0;
      var preTax = afterDisc + rushAmt;
      var tax = preTax * RATES.taxRate;
      var total = preTax + tax;

      var ep = document.getElementById('estPrice');
      if (ep) ep.textContent = count > 0 ? '$' + total.toFixed(2) : '$0';

      var el = document.getElementById('estLines');
      if (el && count > 0) {
        var h = '<div class="el-row"><span>' + count + ' rug' + (count > 1 ? 's' : '') + ', ' + sqftTotal + ' sqft</span><span>$' + (sub - stainFee - mothFee).toFixed(2) + '</span></div>';
        if (stainFee) h += '<div class="el-row"><span>Stain protection</span><span>$' + stainFee.toFixed(2) + '</span></div>';
        if (mothFee) h += '<div class="el-row"><span>Moth prevention</span><span>$' + mothFee.toFixed(2) + '</span></div>';
        if (disc) h += '<div class="el-row el-green"><span>Discount (' + (disc*100) + '%)</span><span>-$' + discAmt.toFixed(2) + '</span></div>';
        if (rushAmt) h += '<div class="el-row el-amber"><span>Rush surcharge</span><span>$' + rushAmt.toFixed(2) + '</span></div>';
        h += '<div class="el-row"><span>Tax (8%)</span><span>$' + tax.toFixed(2) + '</span></div>';
        el.innerHTML = h;
      } else if (el) { el.innerHTML = ''; }

      var fb = document.getElementById('finalBar');
      if (fb && count > 0) {
        fb.innerHTML = '<div class="fb-inner"><span class="fb-label">Estimated Total</span><span class="fb-price">$' + total.toFixed(2) + '</span><span class="fb-meta">' + count + ' rug' + (count > 1 ? 's' : '') + ' &middot; ' + sqftTotal + ' sqft &middot; ' + (rush ? 'Rush' : 'Standard') + '</span></div>';
      }

      return { count: count, total: total, rush: rush };
    }

    function goTo(n) {
      for (var i = 1; i <= 3; i++) {
        var s = document.getElementById('step' + i);
        if (s) s.style.display = i === n ? '' : 'none';
      }
      var steps = document.querySelectorAll('.progress-step');
      for (var j = 0; j < steps.length; j++) {
        var sn = Number(steps[j].dataset.step);
        if (sn <= n) { steps[j].classList.add('active'); } else { steps[j].classList.remove('active'); }
      }
      var fills = document.querySelectorAll('.progress-fill');
      if (fills[0]) fills[0].style.width = n >= 2 ? '100%' : '0%';
      if (fills[1]) fills[1].style.width = n >= 3 ? '100%' : '0%';
      document.getElementById('quote').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Wire the first card that's already in the HTML
    var firstCard = document.querySelector('.rug-card');
    if (firstCard) wireCard(firstCard);

    // Add rug button
    document.getElementById('addRugBtn').addEventListener('click', function() {
      var wrap = document.getElementById('rugCards');
      var card = makeCard();
      wrap.appendChild(card);
      wireCard(card);
      calc();
    });

    // Navigation
    document.getElementById('toStep2').addEventListener('click', function() { calc(); goTo(2); });
    document.getElementById('toStep3').addEventListener('click', function() { calc(); goTo(3); });
    document.getElementById('backTo1').addEventListener('click', function() { goTo(1); });
    document.getElementById('backTo2').addEventListener('click', function() { goTo(2); });

    // Recalculate on step 2 option changes
    var step2inputs = document.querySelectorAll('#step2 input');
    for (var k = 0; k < step2inputs.length; k++) {
      step2inputs[k].addEventListener('change', calc);
    }

    // Submit
    document.getElementById('submitBtn').addEventListener('click', function() {
      var name = document.getElementById('leadName').value.trim();
      var phone = document.getElementById('leadPhone').value.trim();
      var email = document.getElementById('leadEmail').value.trim();
      if (!name || !phone || !email) { alert('Please complete all required fields.'); return; }

      var r = calc();
      document.getElementById('successDetail').innerHTML =
        '<p><strong>' + name + '</strong> &mdash; we\'ll reach you at ' + email + '</p>' +
        '<p>Estimate: <strong>$' + r.total.toFixed(2) + '</strong> for ' + r.count + ' rug' + (r.count > 1 ? 's' : '') + '</p>';
      for (var i = 1; i <= 3; i++) { var s = document.getElementById('step' + i); if (s) s.style.display = 'none'; }
      document.getElementById('progressBar').style.display = 'none';
      document.getElementById('stepDone').style.display = '';
    });
  })();
</script>

<style>
  .quote-section {
    background: var(--charcoal);
  }

  .quote-layout {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 56px;
    align-items: start;
  }

  /* Editorial left */
  .quote-editorial h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 400;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .ed-rule {
    width: 32px;
    height: 1px;
    background: var(--gold);
    margin-bottom: 16px;
  }

  .quote-editorial > p {
    color: rgba(255,255,255,0.5);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .ed-secondary {
    margin-bottom: 32px !important;
    color: rgba(255,255,255,0.35) !important;
    font-size: 0.85rem !important;
  }

  .ed-image {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .ed-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.8) brightness(0.9);
  }

  /* Form card */
  .quote-form-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 36px;
  }

  /* Progress */
  .progress-bar {
    display: flex;
    align-items: center;
    margin-bottom: 32px;
  }

  .progress-step {
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0.35;
    transition: opacity 0.3s;
  }

  .progress-step.active { opacity: 1; }

  .p-num {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    background: var(--stone-100);
    color: var(--stone-500);
    transition: all 0.3s;
  }

  .progress-step.active .p-num {
    background: var(--charcoal);
    color: var(--white);
  }

  .p-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--stone-500);
  }

  .progress-line {
    flex: 1;
    height: 1px;
    background: var(--stone-100);
    margin: 0 12px;
    position: relative;
    overflow: hidden;
  }

  .progress-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0;
    background: var(--gold);
    transition: width 0.4s ease;
  }

  /* Rug cards */
  .rug-card {
    border: 1px solid var(--stone-100);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 12px;
    transition: border-color 0.3s;
  }

  .rug-card:hover {
    border-color: var(--stone-300);
  }

  .quote-form-card :global(.rc-head) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .quote-form-card :global(.rc-title) {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--charcoal);
  }

  .quote-form-card :global(.rc-remove) {
    background: none;
    border: none;
    color: var(--stone-300);
    font-size: 1.3rem;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
  }

  .quote-form-card :global(.rc-remove:hover) { color: #b44; }

  .rc-grid,
  .quote-form-card :global(.rc-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .rc-field,
  .quote-form-card :global(.rc-field) {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .rc-field-full,
  .quote-form-card :global(.rc-field-full) {
    grid-column: 1 / -1;
  }

  .rc-field label,
  .quote-form-card :global(.rc-field label) {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--stone-500);
  }

  .rc-field select,
  .rc-field input,
  .quote-form-card :global(.rc-field select),
  .quote-form-card :global(.rc-field input) {
    padding: 10px 12px;
    border: 1px solid var(--stone-100);
    border-radius: var(--radius);
    font-size: 0.88rem;
    font-family: var(--font-sans);
    background: var(--warm-white);
    color: var(--charcoal);
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  .rc-field select:focus,
  .rc-field input:focus,
  .quote-form-card :global(.rc-field select:focus),
  .quote-form-card :global(.rc-field input:focus) {
    outline: none;
    border-color: var(--gold);
  }

  .rc-foot,
  .quote-form-card :global(.rc-foot) {
    display: flex;
    justify-content: space-between;
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px solid var(--stone-100);
    font-size: 0.8rem;
  }

  .rc-sqft,
  .quote-form-card :global(.rc-sqft) { color: var(--stone-500); }
  .rc-price,
  .quote-form-card :global(.rc-price) { font-weight: 600; color: var(--charcoal); }

  .btn-add {
    width: 100%;
    padding: 12px;
    border: 1px dashed var(--stone-200);
    border-radius: var(--radius);
    background: transparent;
    color: var(--stone-500);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
    letter-spacing: 0.02em;
    margin-bottom: 20px;
  }

  .btn-add:hover {
    border-color: var(--gold);
    color: var(--charcoal);
  }

  .step-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4px;
  }

  .btn-text {
    background: none;
    border: none;
    color: var(--stone-500);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    padding: 8px 0;
    font-family: var(--font-sans);
    transition: color 0.2s;
  }

  .btn-text:hover { color: var(--charcoal); }

  /* Step 2 */
  .field-group { margin-bottom: 24px; }

  .field-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--charcoal);
    margin-bottom: 10px;
  }

  .toggle-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .toggle-card { cursor: pointer; }
  .toggle-card input { display: none; }

  .toggle-inner {
    border: 1px solid var(--stone-100);
    border-radius: var(--radius);
    padding: 14px 16px;
    text-align: center;
    transition: all 0.2s;
  }

  .toggle-inner strong {
    display: block;
